{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ddalkak/bridge.schema.json",
  "title": "Ddalkak Design Bridge",
  "description": "Figma를 무손실로 정규화한 플랫폼 중립 디자인 브릿지(v2.1). 토큰, MCP 상세정보, 스크린샷 교차검증, 적응형 화면 조건, 비전 의미 레이어를 담는다. bridge 단계가 산출하고 plan/code/verify가 소비하는 SSOT. 규칙: figma-extraction-rules.md",
  "type": "object",
  "required": ["meta", "tokens", "screens"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["figmaUrl", "mode", "schemaVersion"],
      "properties": {
        "figmaUrl": { "type": "string" },
        "mode": { "enum": ["section", "page"] },
        "schemaVersion": { "enum": ["2.0", "2.1"], "description": "2.1 = 비전 의미 레이어(semanticRole/source/confidence) 추가. 2.0 파일도 유효(신필드는 전부 optional)" },
        "fidelity": { "enum": ["lossless", "summary"], "default": "lossless", "description": "lossless=구조 접기만 하고 속성·자산 전량 캡처, summary=축약 허용" },
        "extractedAt": { "type": "string" },
        "extractorFingerprint": { "type": "string", "description": "스키마·규칙·변환기 버전 지문. sourceFingerprint와 둘 다 같을 때만 기존 bridge 재사용" },
        "coordinateSpace": { "$ref": "#/$defs/coordinateSpace" },
        "completeness": { "enum": ["full", "partial"], "description": "partial이면 errors에 실패한 추출 패스를 기록한다. rules §6/§15" },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pass", "reason"],
            "properties": {
              "pass": { "enum": ["structure", "detail", "tokens", "component-map", "assets", "screenshots", "semantic"] },
              "tool": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "description": "이름→원본값 사전. 노드에서 '@color.primary'처럼 참조하면 여기서 원본 복원. 토큰 참조를 써도 무손실인 근거.",
      "properties": {
        "color":   { "type": "object", "additionalProperties": { "type": "string" } },
        "type":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/typography" } },
        "spacing": { "type": "object", "additionalProperties": { "type": "number" } },
        "radius":  { "type": "object", "additionalProperties": { "type": ["number", "array"] } },
        "effect":  { "type": "object", "additionalProperties": { "$ref": "#/$defs/effect" } }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "nodes"],
        "properties": {
          "name":  { "type": "string" },
          "frame": { "type": "object", "properties": { "w": { "type": "number" }, "h": { "type": "number" } } },
          "breakpoint":   { "enum": ["mobile", "tablet", "desktop", "default"], "description": "하위 호환용 화면 이름표. 실제 적응 조건은 adaptive에 기록. rules §5" },
          "variantGroup": { "type": "string", "description": "같은 논리 화면의 breakpoint들을 묶는 이름. rules §5" },
          "adaptive":     { "$ref": "#/$defs/adaptiveVariant" },
          "environment":  { "$ref": "#/$defs/environment" },
          "screenshot":   { "type": "string", "description": "이 화면의 스크린샷 asset id. 교차검증(rules §8)과 verify 단계가 재사용." },
          "reconciliation": { "$ref": "#/$defs/reconciliation" },
          "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id":     { "type": "string" },
          "kind":   { "enum": ["image", "vector", "screenshot"], "description": "screenshot=화면 교차검증용, 나머지=디자인 자산" },
          "export": { "type": "string", "description": "저장 경로 (download_assets로 실제 파일 확보. rules §2/§6)" },
          "format": { "enum": ["svg", "png", "jpg", "webp"] }
        }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type":     { "enum": ["frame", "group", "text", "image", "vector", "shape", "line", "ellipse", "component", "instance"] },
        "nodeId":   { "type": "string", "description": "Figma data-node-id. 원본 추적용이며 화면 간 동일성 키와는 구분한다" },
        "matchKey": { "type": "string", "description": "같은 adaptive group의 화면 변형 사이에서 동일한 논리 노드를 연결하는 안정 키. 확신 있을 때만 기록. rules §5" },
        "name":     { "type": "string", "description": "Figma 레이어 이름 (퍼블 시맨틱 힌트)" },
        "content":  { "type": "string", "description": "text 노드의 전체 평문 (편의용). 부분 스타일은 runs 참조" },
        "contentExpr": { "type": "string", "description": "정적으로 해석하지 못한 원본 텍스트 표현식. 조용한 소실 방지용" },
        "runs":     { "type": "array", "items": { "$ref": "#/$defs/textRun" }, "description": "text 노드의 부분 스타일 구간 (mixed runs 무손실)" },
        "ref":      { "type": "string", "description": "image/vector 노드가 가리키는 assets[].id" },
        "layout":   { "$ref": "#/$defs/layout" },
        "constraints": { "$ref": "#/$defs/constraints" },
        "style":    { "$ref": "#/$defs/style" },
        "bbox":     { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4, "description": "[x, y, w, h] (부모 프레임 기준)" },
        "size":     { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2, "description": "[w, h]. flow 자식처럼 위치를 부모 layout이 결정할 때 사용" },
        "sizing":   { "$ref": "#/$defs/sizing" },
        "behavior": { "$ref": "#/$defs/behavior" },
        "textBehavior": { "$ref": "#/$defs/textBehavior" },
        "assetFit": { "enum": ["cover", "contain", "fill", "none"], "description": "image/vector 콘텐츠의 플랫폼 중립 크기 맞춤 방식" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "componentName":           { "type": "string", "description": "type=component/instance일 때. rules §3" },
        "isDesignSystemComponent": { "type": "boolean" },
        "mappedCodeComponent":     { "type": ["string", "null"] },
        "componentProps":          { "type": "object" },
        "semanticRole": { "type": "string", "description": "비전이 부여한 의미 역할 (kebab-case: hero, cta-button, card-list …). 수치가 아닌 의미 힌트. rules §11-1" },
        "source":       { "enum": ["mcp", "vision", "inferred"], "description": "값의 출처. 생략 시 mcp. vision = §8 missing-node를 스크린샷으로 backfill(수치는 추정값). inferred = 디자인 원본에 없는 합성 래퍼 노드(재그룹핑 추론, rules §12-2)" },
        "confidence":   { "type": "number", "minimum": 0, "maximum": 1, "description": "source=vision일 때 필수. verify 단계 우선 확인 근거. rules §11-2" },
        "suggestedComponent": { "type": "string", "description": "Figma 컴포넌트는 아니지만 반복 구조라 코드에서 컴포넌트로 만들어야 하는 것의 제안 이름(PascalCase). 같은 값 = 같은 컴포넌트의 발생 → plan/code가 컴포넌트 1개 + .map()으로 계획. componentName(§3 실제 컴포넌트)과 동시 사용 불가. rules §12-1" },
        "suggestedProps":     { "type": "object", "description": "suggestedComponent 발생 간 달라지는 값(prop 후보). 예: { \"title\": \"감사했어요\" }. rules §12-1" }
      }
    },
    "layout": {
      "type": "object",
      "description": "오토레이아웃. rules §7",
      "properties": {
        "mode":    { "enum": ["row", "column", "grid", "wrap", "none"], "description": "wrap은 v2.0 호환값. 신규 산출은 row|column + wrap 필드를 사용" },
        "wrap":    { "enum": ["no-wrap", "wrap"] },
        "grid":    { "$ref": "#/$defs/grid" },
        "padding": { "type": "array", "items": { "type": ["number", "string"] }, "minItems": 4, "maxItems": 4, "description": "[top, right, bottom, left]. 숫자 또는 '@spacing.*' 토큰 참조" },
        "gap":     { "type": ["number", "string"], "description": "숫자 또는 '@spacing.md' 토큰 참조" },
        "primaryAxisAlign": { "enum": ["start", "center", "end", "space-between"] },
        "counterAxisAlign": { "enum": ["start", "center", "end", "stretch"] },
        "sizing":  {
          "type": "object",
          "properties": {
            "horizontal": { "enum": ["hug", "fill", "fixed"] },
            "vertical":   { "enum": ["hug", "fill", "fixed"] }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "description": "부모 리사이즈 시 이 노드의 반응 규칙. rules §5. anchorX/anchorY는 MCP 코드가 준 앵커 원형(무손실, rules §8-3) — bbox는 캡처 프레임 크기에서의 환산값일 뿐이므로, 퍼센트/반대변 앵커는 원형을 함께 보존해야 code가 반응형 배치를 재현할 수 있다",
      "properties": {
        "horizontal": { "enum": ["left", "right", "left-right", "center", "scale"] },
        "vertical":   { "enum": ["top", "bottom", "top-bottom", "center", "scale"] },
        "anchorX": { "$ref": "#/$defs/anchor" },
        "anchorY": { "$ref": "#/$defs/anchor" }
      }
    },
    "anchor": {
      "type": "object",
      "description": "축 하나의 앵커 원형. percent: 부모 크기 P% + offset 위치. opposite: 반대변에서 offset. stretch: 시작·끝 inset. translate: 앵커가 요소의 중심 기준",
      "required": ["kind"],
      "properties": {
        "kind":      { "enum": ["percent", "opposite", "stretch"] },
        "percent":   { "type": "number" },
        "offset":    { "type": "number" },
        "start":     { "type": "number", "description": "stretch 시작변 inset. 가로축은 left, 세로축은 top에 해당" },
        "end":       { "type": "number", "description": "stretch 끝변 inset. 가로축은 right, 세로축은 bottom에 해당" },
        "translate": { "type": "boolean" }
      }
    },
    "coordinateSpace": {
      "type": "object",
      "required": ["unit"],
      "properties": {
        "unit": { "enum": ["design-unit", "px", "pt", "dp"], "description": "출처가 명시되지 않으면 design-unit. 플랫폼 소비 단계가 px/pt/dp로 해석" },
        "scale": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "adaptiveVariant": {
      "type": "object",
      "required": ["group", "variant", "source"],
      "properties": {
        "group": { "type": "string" },
        "variant": { "type": "string", "description": "mobile 같은 고정 enum이 아닌 원본 변형 이름" },
        "conditions": {
          "type": "object",
          "properties": {
            "width": { "$ref": "#/$defs/range" },
            "height": { "$ref": "#/$defs/range" },
            "orientation": { "enum": ["portrait", "landscape", "square"] },
            "platform": { "enum": ["web", "ios", "android", "desktop", "unknown"] },
            "colorScheme": { "enum": ["light", "dark"] }
          }
        },
        "source": { "enum": ["observed", "inferred"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "range": {
      "type": "object",
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "orientation": { "enum": ["portrait", "landscape", "square"] },
        "platform": { "enum": ["web", "ios", "android", "desktop", "unknown"] },
        "density": { "type": "number", "exclusiveMinimum": 0 },
        "colorScheme": { "enum": ["light", "dark"] },
        "safeArea": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4, "description": "[top,right,bottom,left]. Figma에 명시된 경우만 기록" }
      }
    },
    "sizing": {
      "type": "object",
      "properties": {
        "horizontal": { "$ref": "#/$defs/sizingAxis" },
        "vertical": { "$ref": "#/$defs/sizingAxis" },
        "aspectRatio": { "type": "number", "exclusiveMinimum": 0 },
        "grow": { "type": "number", "minimum": 0 },
        "shrink": { "type": "number", "minimum": 0 }
      }
    },
    "sizingAxis": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["fixed", "content", "fill", "fraction"] },
        "value": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "behavior": {
      "type": "object",
      "properties": {
        "positioning": { "enum": ["flow", "overlay"] },
        "visibility": { "enum": ["visible", "hidden"] },
        "overflowX": { "enum": ["visible", "clip", "scroll", "auto"] },
        "overflowY": { "enum": ["visible", "clip", "scroll", "auto"] }
      }
    },
    "textBehavior": {
      "type": "object",
      "properties": {
        "wrap": { "enum": ["wrap", "no-wrap"] },
        "overflow": { "enum": ["visible", "clip", "ellipsis"] },
        "maxLines": { "type": "integer", "minimum": 1 },
        "autoSize": { "enum": ["fixed", "height", "width-height"] }
      }
    },
    "grid": {
      "type": "object",
      "properties": {
        "columns": { "type": "array", "items": { "$ref": "#/$defs/gridTrack" } },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/gridTrack" } }
      }
    },
    "gridTrack": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["content", "fixed", "fill", "fraction"] },
        "value": { "type": "number" }
      }
    },
    "style": {
      "type": "object",
      "description": "열거된 시각 속성. 값은 '@token.path' 참조 또는 raw 리터럴 — 둘 중 하나로 항상 채워 무손실 보장. rules §4",
      "properties": {
        "fills":        { "type": "array", "items": { "$ref": "#/$defs/fill" } },
        "strokes":      { "type": "array", "items": { "$ref": "#/$defs/stroke" } },
        "effects":      { "type": "array", "items": { "oneOf": [{ "$ref": "#/$defs/effect" }, { "type": "string", "pattern": "^@effect\\." }] } },
        "cornerRadius": { "type": ["number", "string", "array"], "description": "숫자 / '@radius.md' / [tl,tr,br,bl]" },
        "opacity":      { "type": "number" },
        "blendMode":    { "type": "string" },
        "clipsContent": { "type": "boolean" },
        "font":         { "description": "text 노드: '@type.body-md' 참조 또는 인라인 typography 객체" }
      }
    },
    "typography": {
      "type": "object",
      "properties": {
        "family":        { "type": "string" },
        "size":          { "type": "number" },
        "weight":        { "type": "number" },
        "lineHeight":    { "type": ["number", "string"] },
        "letterSpacing": { "type": ["number", "string"] },
        "textAlign":     { "enum": ["left", "center", "right", "justify"] },
        "textCase":      { "enum": ["none", "upper", "lower", "title"] },
        "textDecoration":{ "enum": ["none", "underline", "line-through"] }
      }
    },
    "textRun": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text":  { "type": "string" },
        "style": { "$ref": "#/$defs/style" }
      }
    },
    "fill": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type":      { "enum": ["solid", "gradient", "image"] },
        "color":     { "type": "string", "description": "solid: '@color.primary' 또는 '#RRGGBB(AA)'" },
        "gradient":  {
          "type": "object",
          "properties": {
            "kind":  { "enum": ["linear", "radial", "angular"] },
            "angle": { "type": "number" },
            "stops": { "type": "array", "items": { "type": "object", "properties": { "color": { "type": "string" }, "position": { "type": "number" } } } }
          }
        },
        "ref":       { "type": "string", "description": "image fill이 가리키는 assets[].id" },
        "scaleMode": { "enum": ["fill", "fit", "tile", "stretch"] },
        "opacity":   { "type": "number" }
      }
    },
    "stroke": {
      "type": "object",
      "properties": {
        "color":  { "type": "string" },
        "weight": { "type": "number" },
        "align":  { "enum": ["inside", "center", "outside"] },
        "dash":   { "type": "array", "items": { "type": "number" } }
      }
    },
    "effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type":   { "enum": ["drop-shadow", "inner-shadow", "layer-blur", "background-blur"] },
        "color":  { "type": "string" },
        "offset": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "radius": { "type": "number" },
        "spread": { "type": "number" }
      }
    },
    "reconciliation": {
      "type": "object",
      "description": "구조 데이터 vs 스크린샷 교차검증 결과. rules §8",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["match", "discrepancies"] },
        "discrepancies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind":   { "enum": ["missing-node", "extra-node", "style-mismatch", "text-mismatch", "position-mismatch"] },
              "detail": { "type": "string" },
              "resolved": { "type": "boolean", "description": "보정했으면 true" },
              "resolution": { "enum": ["re-extract", "vision-backfill"], "description": "보정 방법. vision-backfill이면 해당 노드에 source/confidence 태깅 필수. rules §8/§11" }
            }
          }
        }
      }
    }
  }
}
